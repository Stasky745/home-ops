CLUSTER_NAME=<cluster-name>

# Space-separated node hostnames (must match talconfig.yaml hostnames)
NODES=<node-1> <node-2> <node-3>

# Per-node IPs — variable name must be NODE_<HOSTNAME_UPPERCASE>
NODE_<NODE-1-UPPERCASE>=<node-1-ip>
NODE_<NODE-2-UPPERCASE>=<node-2-ip>
NODE_<NODE-3-UPPERCASE>=<node-3-ip>

# Comma-separated IPs for all nodes
ALL_NODE_IPS=<node-1-ip>,<node-2-ip>,<node-3-ip>

# First control plane node IP (used for bootstrap)
BOOTSTRAP_NODE_IP=<node-1-ip>
